{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../dist-types/shared",
    "rootDir": ".",
    "tsBuildInfoFile": "../dist-types/shared.tsbuildinfo",
    "module": "ESNext",
    "target": "es2022",
    "lib": ["esnext", "dom", "dom.iterable"],
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "baseUrl": "..",
    "types": ["node"],
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.bak*",
    "schema.ts.bak_*",
    "exit-backup/**"
  ]
}
